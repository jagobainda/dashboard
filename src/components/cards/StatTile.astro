---
import { formatNumber } from "../../lib/stats";

interface Props {
    label: string;
    value: number;
    hint?: string;
}

const { label, value, hint } = Astro.props;
---

<article
    class="dashboard-card rounded-xl bg-(--bg-secondary) p-5 shadow-[4px_4px_8px_var(--shadow-light)] transition-colors duration-300"
>
    <p class="m-0 text-sm text-(--text-muted)">{label}</p>
    <p class="stat-value m-0 mt-1 text-4xl font-bold" data-value={value}>{formatNumber(value)}</p>
    {hint && <p class="m-0 mt-1 text-xs text-(--text-muted)">{hint}</p>}
</article>
