---

import { formatNumber, formatShare } from "../../lib/stats";
import { seriesColor } from "../../lib/viz";

interface Props {

    share: number;
    value: number;
    total: number;
    label: string;
}

const { share, value, total, label } = Astro.props;
const color = seriesColor(1);
---

<div>
    <div class="mb-1.5 flex items-baseline justify-between gap-3 text-sm">
        <span>{label}</span>
        <span class="font-bold tabular-nums">
            {formatShare(share)}
            <span class="ml-1 font-normal text-(--text-muted)">({formatNumber(value)} de {formatNumber(total)})</span>
        </span>
    </div>
    <div
        class="h-2.5 w-full rounded-xs bg-(--chart-track)"
        role="meter"
        aria-valuemin="0"
        aria-valuemax="100"
        aria-valuenow={Math.round(share * 100)}
        aria-label={label}
    >
        <div class="h-full rounded-xs" style={`width:${(share * 100).toFixed(1)}%;background:${color}`}></div>
    </div>
</div>
