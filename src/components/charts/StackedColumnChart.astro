---
import { formatNumber } from "../../lib/stats";
import { stackSegmentPath, yTicks } from "../../lib/viz";

interface Segment {
    label: string;
    value: number;
    color: string;
}

interface Column {
    label: string;
    segments: Segment[];
}

interface Props {
    columns: Column[];

    series: { label: string; color: string }[];

    labelEvery?: number;
}

const { columns, series, labelEvery = 1 } = Astro.props;

const W = 640;
const H = 230;
const M = { top: 20, right: 8, bottom: 24, left: 36 };
const plotW = W - M.left - M.right;
const plotH = H - M.top - M.bottom;
const GAP = 2;

const totals = columns.map(c => c.segments.reduce((sum, s) => sum + s.value, 0));
const maxValue = Math.max(...totals, 1);
const ticks = yTicks(maxValue);
const scaleMax = ticks[ticks.length - 1] ?? maxValue;
const y = (v: number): number => M.top + plotH - (v / scaleMax) * plotH;

const slotW = plotW / columns.length;
const barW = Math.min(24, slotW * 0.7);
const labelAllCaps = columns.length <= 14;
const maxIndex = totals.indexOf(Math.max(...totals));
---

<svg viewBox={`0 0 ${W} ${H}`} class="w-full" role="img" aria-label="Visitas por día y servicio">
    {
        ticks.map(tick => (
            <>
                <line
                    x1={M.left}
                    x2={W - M.right}
                    y1={y(tick)}
                    y2={y(tick)}
                    stroke={tick === 0 ? "var(--chart-axis)" : "var(--chart-grid)"}
                    stroke-width="1"
                />
                <text
                    x={M.left - 6}
                    y={y(tick) + 3}
                    text-anchor="end"
                    class="fill-(--text-muted) text-[10px] tabular-nums"
                >
                    {formatNumber(tick)}
                </text>
            </>
        ))
    }

    {
        columns.map((column, i) => {
            const x = M.left + i * slotW + (slotW - barW) / 2;
            const visible = column.segments.filter(s => s.value > 0);
            const total = totals[i] ?? 0;
            let acc = 0;
            return (
                <g>
                    {visible.map((segment, j) => {
                        const yBottom = y(acc) - (j > 0 ? GAP : 0);
                        acc += segment.value;
                        const isTop = j === visible.length - 1;
                        const yTop = y(acc);
                        return yBottom - yTop > 0.5 ? (
                            <path
                                d={stackSegmentPath(x, yTop, barW, yBottom, isTop)}
                                fill={segment.color}
                                class="chart-mark"
                            />
                        ) : null;
                    })}
                    <rect
                        x={M.left + i * slotW}
                        y={M.top}
                        width={slotW}
                        height={plotH}
                        fill="transparent"
                        class="outline-none"
                        tabindex="0"
                        role="img"
                        aria-label={`${column.label}: ${formatNumber(total)} visitas`}
                        data-tooltip={JSON.stringify({
                            title: column.label,
                            rows: [
                                { label: "total", value: formatNumber(total) },
                                ...column.segments.map(s => ({
                                    label: s.label,
                                    value: formatNumber(s.value),
                                    color: s.color,
                                })),
                            ],
                        })}
                    />
                    {(labelAllCaps || i === maxIndex) && total > 0 && (
                        <text
                            x={x + barW / 2}
                            y={y(total) - 5}
                            text-anchor="middle"
                            class="fill-(--text-color) text-[11px] font-bold tabular-nums"
                        >
                            {formatNumber(total)}
                        </text>
                    )}
                    {i % labelEvery === 0 && (
                        <text
                            x={M.left + i * slotW + slotW / 2}
                            y={H - 8}
                            text-anchor="middle"
                            class="fill-(--text-muted) text-[10px]"
                        >
                            {column.label}
                        </text>
                    )}
                </g>
            );
        })
    }
</svg>

<ul class="mt-3 flex list-none flex-wrap gap-x-5 gap-y-1 p-0 text-sm">
    {
        series.map(entry => (
            <li class="flex items-center gap-2">
                <span class="inline-block h-3 w-3 shrink-0 rounded-xs" style={`background:${entry.color}`} />
                <span class="font-mono text-xs">{entry.label}</span>
            </li>
        ))
    }
</ul>

<style>
    .chart-mark {
        transition: filter 0.15s ease-in-out;
    }
    g:hover .chart-mark,
    g:focus-within .chart-mark {
        filter: brightness(1.12);
    }
</style>
